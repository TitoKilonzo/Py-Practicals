      >>SOURCE FORMAT IS FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. MARKSPROC.
AUTHOR. TITO-KINYAMBU.
DATE-WRITTEN. 2026-07-13.

ENVIRONMENT DIVISION.
CONFIGURATION SECTION.
SOURCE-COMPUTER. GnuCOBOL.
OBJECT-COMPUTER. GnuCOBOL.

DATA DIVISION.
WORKING-STORAGE SECTION.

01  WS-MARK              PIC 999.
01  WS-COUNTER           PIC 99.
01  WS-TOTAL             PIC 9(4).
01  WS-AVERAGE           PIC 999V99.
01  WS-HIGHEST           PIC 999.
01  WS-LOWEST            PIC 999.

01  WS-TOTAL-DISPLAY     PIC ZZZ9.
01  WS-AVERAGE-DISPLAY   PIC ZZ9.99.
01  WS-HIGH-DISPLAY      PIC ZZ9.
01  WS-LOW-DISPLAY       PIC ZZ9.

01  WS-SEPARATOR         PIC X(40) VALUE ALL "-".

PROCEDURE DIVISION.

MAIN-LOGIC.
    MOVE 0 TO WS-TOTAL

    PERFORM VARYING WS-COUNTER FROM 1 BY 1 UNTIL WS-COUNTER > 10

        DISPLAY "Enter mark " WS-COUNTER " of 10: "
        ACCEPT WS-MARK

        ADD WS-MARK TO WS-TOTAL

        IF WS-COUNTER = 1
            MOVE WS-MARK TO WS-HIGHEST
            MOVE WS-MARK TO WS-LOWEST
        ELSE
            IF WS-MARK > WS-HIGHEST
                MOVE WS-MARK TO WS-HIGHEST
            END-IF
            IF WS-MARK < WS-LOWEST
                MOVE WS-MARK TO WS-LOWEST
            END-IF
        END-IF

    END-PERFORM

    COMPUTE WS-AVERAGE ROUNDED = WS-TOTAL / 10

    MOVE WS-TOTAL    TO WS-TOTAL-DISPLAY
    MOVE WS-AVERAGE  TO WS-AVERAGE-DISPLAY
    MOVE WS-HIGHEST  TO WS-HIGH-DISPLAY
    MOVE WS-LOWEST   TO WS-LOW-DISPLAY

    DISPLAY " "
    DISPLAY WS-SEPARATOR
    DISPLAY "Marks entered   : 10"
    DISPLAY WS-SEPARATOR
    DISPLAY "Class Total     : " WS-TOTAL-DISPLAY
    DISPLAY "Class Average   : " WS-AVERAGE-DISPLAY
    DISPLAY "Highest Mark    : " WS-HIGH-DISPLAY
    DISPLAY "Lowest Mark     : " WS-LOW-DISPLAY
    DISPLAY WS-SEPARATOR
    DISPLAY " "

    STOP RUN.
